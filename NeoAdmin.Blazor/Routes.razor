@using NeoAdmin.Blazor.Components

<Router AppAssembly="@typeof(LayoutAdmin).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(LayoutAdmin)" />
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <LayoutView Layout="@typeof(LayoutEmpty)">
            <p>页面不存在。</p>
        </LayoutView>
    </NotFound>
</Router>
