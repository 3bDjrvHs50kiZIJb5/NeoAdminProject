@namespace NeoAdmin.Blazor.Components
@typeparam TItem where TItem : class
@typeparam TChild where TChild : class
@typeparam TKey
@using FreeSql
@using NeoAdmin.Blazor.Utils
@using Microsoft.Extensions.Logging
@using Microsoft.AspNetCore.Components.Web.Virtualization
@inject IFreeSql FreeSql
@inject IToastService ToastService
@inject ILoggerFactory LoggerFactory

<Dialog Open="@(Item != null)" OpenChanged="HandleOpenChanged">
  <DialogContent Variant="DialogContentVariant.Form" Class="@DialogContentSize.ToDialogClass()" CloseOnEscape="false">
    <div class="flex max-h-[min(90vh,48rem)] flex-col">
      <div class="shrink-0">
        <DialogHeader>
          <DialogTitle>@(string.IsNullOrWhiteSpace(Title) ? "分配" : Title)</DialogTitle>
          <DialogDescription>勾选需要关联的项，然后确认保存。</DialogDescription>
        </DialogHeader>
      </div>
      @if (Item != null)
      {
        <div class="flex min-h-0 flex-1 flex-col gap-3 overflow-hidden">
          @if (IsSearchText)
          {
            <div class="shrink-0">
              <Input Type="InputType.Search" Placeholder="@SearchPlaceholder" @bind-Value="searchText"
                @bind-Value:after="HandleSearchTextChangedAsync" />
            </div>
          }
          <div
            class="max-h-50vh min-h-0 flex-1 overflow-x-hidden overflow-y-auto overscroll-contain rounded-md border p-3">
            @if (isLoadingChoices)
            {
              <p class="text-sm text-muted-foreground">加载中…</p>
            }
            else if (ShowSearchRequiredHint)
            {
              <p class="text-sm text-muted-foreground">@SearchRequiredHint</p>
            }
            else if (choices.Count == 0)
            {
              <p class="text-sm text-muted-foreground">未找到匹配项</p>
            }
            else
            {
              <Virtualize Items="choices" Context="child" ItemSize="36" OverscanCount="8">
                <ItemContent>
                  @{
                    TKey key = KeySelector(child);
                  }
                  <div class="flex items-center gap-2 py-0.5" style="@GetIndentStyle(child)">
                    <Checkbox Checked="@IsSelected(key)" CheckedChanged="@(value => ToggleAsync(key, value))"
                      Id="@GetChoiceElementId(key)" />
                    <Label For="@GetChoiceElementId(key)" Class="cursor-pointer font-normal">
                      @if (RowTemplate != null)
                      {
                        @RowTemplate(child)
                      }
                      else
                      {
                        @DisplayText(child)
                      }
                    </Label>
                  </div>
                </ItemContent>
              </Virtualize>
            }
          </div>
          @if (ShowChoicesPaging)
          {
            <div class="flex shrink-0 flex-wrap items-center justify-start gap-2 text-sm text-muted-foreground">
              <div class="flex items-center gap-2">
                <Button Variant="ButtonVariant.Link" Size="ButtonSize.Small" Class="h-auto px-0"
                  Disabled="@(choicesPageNumber <= 1 || isLoadingChoices)"
                  OnClick="GoToPreviousChoicesPageAsync">上一页</Button>
                <span>第 @choicesPageNumber / @ChoicesTotalPages 页（共 @choicesTotal 项）</span>
                <Button Variant="ButtonVariant.Link" Size="ButtonSize.Small" Class="h-auto px-0"
                  Disabled="@(choicesPageNumber >= ChoicesTotalPages || isLoadingChoices)"
                  OnClick="GoToNextChoicesPageAsync">下一页</Button>
              </div>
            </div>
          }
        </div>
        <div class="shrink-0">
          <DialogFooter Class="mt-4 flex flex-wrap justify-between gap-2">
            <Button Variant="ButtonVariant.Outline" OnClick="ResetSelection">重置</Button>
            <div class="flex gap-2">
              <Button Variant="ButtonVariant.Outline" OnClick="Close">取消</Button>
              <Button Variant="ButtonVariant.Default" OnClick="SaveAsync">确认选择 @selectedKeys.Count 项</Button>
            </div>
          </DialogFooter>
        </div>
      }
    </div>
  </DialogContent>
</Dialog>

@code {
  private ILogger? _logger;
  private ILogger Logger => _logger ??= LoggerFactory.CreateLogger($"{typeof(NeoAllocTable<,,>).Name}<{typeof(TItem).Name},{typeof(TChild).Name}>");

  [Parameter] public TItem? Item { get; set; }
  [Parameter] public EventCallback<TItem?> ItemChanged { get; set; }
  [Parameter] public string Title { get; set; } = string.Empty;
  [Parameter] public CrudDialogContentSize DialogContentSize { get; set; } = CrudDialogContentSize.X2l;
  [Parameter] public bool IsSearchText { get; set; } = true;
  [Parameter] public string SearchPlaceholder { get; set; } = "搜索..";
  [Parameter] public Func<TChild, TKey> KeySelector { get; set; } = default!;
  [Parameter] public Func<TChild, string> DisplayText { get; set; } = default!;
  [Parameter] public Func<TChild, int>? LevelSelector { get; set; }
  /// <summary>
  /// 树形列表父子勾选联动（对齐旧版 NovaAdminTable.IsAutoSelectParent）。
  /// 需配合 LevelSelector，且 choices 为深度优先扁平顺序。
  /// </summary>
  [Parameter] public bool IsCascadeSelection { get; set; } = true;
  [Parameter] public RenderFragment<TChild>? RowTemplate { get; set; }
  [Parameter] public EventCallback<CrudQueryEventArgs<TChild>> OnQuery { get; set; }
  /// <summary>分页加载可选项（支持轻量投影）；优先于 OnQuery + FreeSql。</summary>
  [Parameter] public Func<NeoAllocChoicesRequest, Task<NeoAllocChoicesResult<TChild>>>? LoadChoicesPagedFunc { get; set; }
  /// <summary>自定义加载可选项（如树形扁平列表）；设置后优先于 OnQuery + FreeSql，且不分页。</summary>
  [Parameter] public Func<string?, Task<List<TChild>>>? LoadChoicesFunc { get; set; }
  [Parameter] public Func<TItem, Task<IReadOnlyCollection<TKey>>>? LoadSelectedKeysAsync { get; set; }
  [Parameter] public Func<TItem, IReadOnlyCollection<TKey>, Task<bool>>? OnSaveAsync { get; set; }
  /// <summary>每页可选项数量；树形全量加载（LoadChoicesFunc）时不分页。</summary>
  [Parameter] public int ChoicesPageSize { get; set; } = 500;
  /// <summary>
  /// 打开弹窗时不预加载可选项，需输入搜索词后再查。
  /// 默认 false：打开弹窗即分页查库；设为 true 时需先搜索。
  /// </summary>
  [Parameter] public bool? DeferChoicesUntilSearch { get; set; }
  [Parameter] public string SearchRequiredHint { get; set; } = "请输入关键词后搜索";

  private readonly HashSet<TKey> selectedKeys = new();
  private List<TChild> choices = new();
  private string? searchText;
  private TItem? loadedForItem;
  private bool isLoadingChoices;
  private int choicesPageNumber = 1;
  private long choicesTotal;

  private bool UsesFullChoicesLoad => LoadChoicesFunc != null;

  private bool EffectiveDeferChoicesUntilSearch =>
    DeferChoicesUntilSearch ?? false;

  private bool ShowSearchRequiredHint =>
    !isLoadingChoices && EffectiveDeferChoicesUntilSearch && string.IsNullOrWhiteSpace(searchText?.Trim());

  private bool ShowChoicesPaging =>
    !UsesFullChoicesLoad && choicesTotal > ChoicesPageSize;

  private int ChoicesTotalPages =>
    choicesTotal <= 0 ? 1 : (int)Math.Ceiling(choicesTotal / (double)ChoicesPageSize);

  protected override async Task OnParametersSetAsync()
  {
    if (Item == null)
    {
      loadedForItem = null;
      choices.Clear();
      selectedKeys.Clear();
      choicesTotal = 0;
      choicesPageNumber = 1;
      isLoadingChoices = false;
      return;
    }

    if (!ReferenceEquals(Item, loadedForItem))
    {
      loadedForItem = Item;
      searchText = null;
      choicesPageNumber = 1;
      choices.Clear();
      choicesTotal = 0;
      await Task.WhenAll(LoadSelectedAsync(), LoadChoicesAsync());
    }
  }

  private async Task LoadSelectedAsync()
  {
    selectedKeys.Clear();
    if (Item == null || LoadSelectedKeysAsync == null)
    {
      return;
    }

    IReadOnlyCollection<TKey> keys = await LoadSelectedKeysAsync(Item);
    foreach (TKey key in keys)
    {
      selectedKeys.Add(key);
    }
  }

  private async Task LoadChoicesAsync()
  {
    if (ShouldDeferChoicesLoad())
    {
      choices = [];
      choicesTotal = 0;
      return;
    }

    isLoadingChoices = true;
    await InvokeAsync(StateHasChanged);
    try
    {
      if (LoadChoicesPagedFunc != null)
      {
        NeoAllocChoicesResult<TChild> result = await LoadChoicesPagedFunc(BuildChoicesRequest());
        choices = result.Items;
        choicesTotal = result.Total;
        return;
      }

      if (LoadChoicesFunc != null)
      {
        choices = await LoadChoicesFunc(searchText?.Trim());
        choicesTotal = choices.Count;
        return;
      }

      ISelect<TChild> select = FreeSql.Select<TChild>();
      CrudQueryEventArgs<TChild> args = new(
        select,
        searchText?.Trim(),
        Array.Empty<CrudFilterInfo>(),
        choicesPageNumber,
        ChoicesPageSize);

      if (OnQuery.HasDelegate)
      {
        await OnQuery.InvokeAsync(args);
      }

      choicesTotal = await select.CountAsync();
      choices = await select.Page(choicesPageNumber, ChoicesPageSize).ToListAsync();
    }
    finally
    {
      isLoadingChoices = false;
    }
  }

  private NeoAllocChoicesRequest BuildChoicesRequest() =>
    new()
    {
      SearchText = searchText?.Trim(),
      PageNumber = choicesPageNumber,
      PageSize = ChoicesPageSize
    };

  private bool ShouldDeferChoicesLoad() =>
    EffectiveDeferChoicesUntilSearch && string.IsNullOrWhiteSpace(searchText?.Trim());

  private async Task HandleSearchTextChangedAsync()
  {
    choicesPageNumber = 1;
    await LoadChoicesAsync();
  }

  private async Task GoToPreviousChoicesPageAsync()
  {
    if (choicesPageNumber <= 1 || isLoadingChoices)
    {
      return;
    }

    choicesPageNumber--;
    await LoadChoicesAsync();
  }

  private async Task GoToNextChoicesPageAsync()
  {
    if (choicesPageNumber >= ChoicesTotalPages || isLoadingChoices)
    {
      return;
    }

    choicesPageNumber++;
    await LoadChoicesAsync();
  }

  private string GetChoiceElementId(TKey key) => $"neo-alloc-{key}";

  private bool IsSelected(TKey key) => selectedKeys.Contains(key);

  private bool UseCascadeSelection => IsCascadeSelection && LevelSelector != null;

  private Task ToggleAsync(TKey key, bool selected)
  {
    if (!UseCascadeSelection)
    {
      SetSelected(key, selected);
      return Task.CompletedTask;
    }

    int index = FindChoiceIndex(key);
    if (index < 0)
    {
      SetSelected(key, selected);
      return Task.CompletedTask;
    }

    ApplyCascadeSelection(index, selected);
    return Task.CompletedTask;
  }

  private void ApplyCascadeSelection(int index, bool selected)
  {
    TreeCascadeSelectionHelper.ApplyCascade(
      choices,
      index,
      selected,
      item => LevelSelector!(item),
      (item, isSelected) => SetSelected(KeySelector(item), isSelected),
      item => IsSelected(KeySelector(item)));
  }

  private int FindChoiceIndex(TKey key)
  {
    for (int index = 0; index < choices.Count; index++)
    {
      if (EqualityComparer<TKey>.Default.Equals(KeySelector(choices[index]), key))
      {
        return index;
      }
    }

    return -1;
  }

  private void SetSelected(TKey key, bool selected)
  {
    if (selected)
    {
      selectedKeys.Add(key);
    }
    else
    {
      selectedKeys.Remove(key);
    }
  }

  private void ResetSelection() => selectedKeys.Clear();

  /// <summary>与菜单管理列表一致：每层 18px，不依赖 Tailwind 是否扫描到 pl-*。</summary>
  private string GetIndentStyle(TChild child)
  {
    int level = LevelSelector?.Invoke(child) ?? 0;
    return level > 0 ? $"padding-left:{level * 18}px" : string.Empty;
  }

  private async Task SaveAsync()
  {
    if (Item == null)
    {
      return;
    }

    if (OnSaveAsync == null)
    {
      ToastService.Error("分配", "未配置 OnSaveAsync，无法保存分配结果。");
      return;
    }

    bool success = await OnSaveAsync(Item, selectedKeys.ToList());
    if (success)
    {
      Logger.LogInformation(
        "分配保存成功：{ItemDesc}，已选 {Count} 项",
        EntityLogHelper.Describe(Item),
        selectedKeys.Count);
      ToastService.Success("分配", "保存成功");
      await Close();
    }
    else
    {
      Logger.LogWarning(
        "分配保存失败：{ItemDesc}，已选 {Count} 项",
        EntityLogHelper.Describe(Item),
        selectedKeys.Count);
    }
  }

  private async Task Close()
  {
    loadedForItem = null;
    choices.Clear();
    selectedKeys.Clear();
    searchText = null;
    choicesPageNumber = 1;
    choicesTotal = 0;
    isLoadingChoices = false;
    await ItemChanged.InvokeAsync(default);
  }

  private async Task HandleOpenChanged(bool open)
  {
    if (!open)
    {
      await Close();
    }
  }
}
