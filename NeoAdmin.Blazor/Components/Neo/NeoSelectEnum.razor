@namespace NeoAdmin.Blazor.Components
@typeparam TEnum where TEnum : struct, Enum
@using NeoAdmin.Blazor.Extensions

<NativeSelect TValue="string"
              Class="w-full"
              Disabled="@Disabled"
              @bind-Value="boundName"
              @bind-Value:after="SyncEnumFromBoundName">
    @foreach (string enumName in Enum.GetNames(typeof(TEnum)))
    {
        <NativeSelectOption Value="@enumName">@GetDisplayLabel(enumName)</NativeSelectOption>
    }
</NativeSelect>

@code {
    [Parameter]
    public TEnum Value { get; set; }

    [Parameter]
    public EventCallback<TEnum> ValueChanged { get; set; }

    [Parameter]
    public EventCallback<TEnum> OnValueChanged { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    private string boundName = string.Empty;

    protected override void OnParametersSet()
    {
        boundName = Value.ToString() ?? string.Empty;
    }

    private async Task SyncEnumFromBoundName()
    {
        if (!Enum.TryParse(boundName, out TEnum parsed))
        {
            return;
        }

        Value = parsed;
        await ValueChanged.InvokeAsync(parsed);
        await OnValueChanged.InvokeAsync(parsed);
    }

    private string GetDisplayLabel(string enumName)
    {
        if (!Enum.TryParse(enumName, out TEnum parsed))
        {
            return enumName;
        }

        return parsed.ToDescription();
    }
}
