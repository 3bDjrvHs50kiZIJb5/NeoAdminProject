@namespace NeoAdmin.Blazor.Components
<ResizablePanelGroup Direction="ResizableDirection.Horizontal"
                     Class="@GetRootClass()"
                     DefaultSizes="@DefaultSizesArray">
    <ResizablePanel MinSize="@FirstPaneMinSize"
                    Class="flex min-h-0 min-w-0 flex-col overflow-hidden">
        @FirstPaneTemplate
    </ResizablePanel>

    <ResizableHandle WithHandle="@ShowBarHandle" />

    <ResizablePanel MinSize="@SecondPaneMinSize"
                    Class="flex min-h-0 min-w-0 flex-col overflow-hidden">
        @SecondPaneTemplate
    </ResizablePanel>
</ResizablePanelGroup>

@code {
    [Parameter] public RenderFragment? FirstPaneTemplate { get; set; }
    [Parameter] public RenderFragment? SecondPaneTemplate { get; set; }

    /// <summary>首栏默认宽度百分比，如 22%。</summary>
    [Parameter] public string Basis { get; set; } = "22%";

    /// <summary>首栏最小宽度；支持百分比（如 15%），像素值将换算为约 15% 下限。</summary>
    [Parameter] public string FirstPaneMinimumSize { get; set; } = "330px";

    [Parameter] public bool ShowBarHandle { get; set; } = true;
    [Parameter] public string? Class { get; set; }

    private double FirstPaneDefaultSize => ParsePercent(Basis, 22);
    private double SecondPaneDefaultSize => 100 - FirstPaneDefaultSize;
    private double FirstPaneMinSize => ParseMinSize(FirstPaneMinimumSize, 15);
    private double SecondPaneMinSize => 30;

    // NeoUI.Blazor 的 ResizablePanelGroup 只会读 DefaultSizes，
    // 各 ResizablePanel 上单独写的 DefaultSize 会被忽略。
    private double[] DefaultSizesArray => new[] { FirstPaneDefaultSize, SecondPaneDefaultSize };

    private string GetRootClass()
    {
        List<string> classes =
        [
            "flex",
            "flex-1",
            "min-h-0",
            "min-w-0",
            "overflow-hidden",
            "gap-2"
        ];

        if (!string.IsNullOrWhiteSpace(Class))
        {
            classes.Add(Class);
        }

        return string.Join(' ', classes);
    }

    private static double ParsePercent(string value, double fallback)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return fallback;
        }

        string trimmed = value.Trim();
        if (trimmed.EndsWith('%') && double.TryParse(trimmed[..^1], out double percent))
        {
            return Math.Clamp(percent, 5, 95);
        }

        return fallback;
    }

    private static double ParseMinSize(string value, double fallback)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return fallback;
        }

        string trimmed = value.Trim();
        if (trimmed.EndsWith('%') && double.TryParse(trimmed[..^1], out double percent))
        {
            return Math.Clamp(percent, 5, 90);
        }

        // Resizable 以百分比约束；像素最小宽在布局层难以精确换算，使用合理默认下限。
        return fallback;
    }
}
