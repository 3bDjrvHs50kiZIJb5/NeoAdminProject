@page "/BBDemo/MarkdownDemo"

<PageTitle>Markdown 演示</PageTitle>

<div class="p-3">
    <h3 class="mb-3">Markdown 演示</h3>

    <p class="text-muted mb-3">
        这是一个最简单的 Markdown 组件示例，保留编辑区和预览区，方便直接体验。
    </p>

    <div style="width: 100%; height: 300px;">
        <Markdown Language="@Language" @bind-Value="@MarkdownString" @bind-Html="@HtmlString" />
    </div>

    <div class="mt-3">
        <textarea class="form-control" rows="6" readonly>@MarkdownString</textarea>
    </div>

    <div class="mt-3">
        <textarea class="form-control" rows="6" readonly>@HtmlString</textarea>
    </div>
</div>

@code {
    private string Language = "zh-CN";

    private string MarkdownString = @"# Markdown 标题

- 项目一
- 项目二

**加粗**、*斜体*、`行内代码`

[查看 Bootstrap Blazor 文档](https://www.blazor.zone/markdown)";

    private string HtmlString = string.Empty;
}
