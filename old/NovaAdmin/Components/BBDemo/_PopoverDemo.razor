@page "/BBDemo/PopoverDemo"

<PageTitle>Popover 演示</PageTitle>

    <div class="card mb-3">
        <div class="card-header">
            <strong>Popover 演示</strong>
        </div>
        <div class="card-body">
            <p class="text-muted mb-3">
                下面演示四个常用场景：基础提示、点击触发、底部显示和自定义模板。
            </p>

            <div class="row g-3">
                <div class="col-12 col-lg-3">
                    <div class="border rounded p-3 h-100 bg-white">
                        <div class="fw-semibold mb-2">基础提示</div>
                        <Popover Title="基础提示"
                                 Content="这里是一个最简单的 Popover，用来放补充说明。"
                                 Placement="Placement.Top"
                                 Trigger="hover focus"
                                 ShowShadow="true">
                            <button type="button" class="btn btn-primary">悬停查看</button>
                        </Popover>
                    </div>
                </div>

                <div class="col-12 col-lg-3">
                    <div class="border rounded p-3 h-100 bg-white">
                        <div class="fw-semibold mb-2">点击触发</div>
                        <Popover Title="点击提示"
                                 Content="这里演示点击触发的 Popover。"
                                 Placement="Placement.Right"
                                 Trigger="click"
                                 ShowShadow="true">
                            <button type="button" class="btn btn-outline-secondary">点击打开</button>
                        </Popover>
                    </div>
                </div>

                <div class="col-12 col-lg-3">
                    <div class="border rounded p-3 h-100 bg-white">
                        <div class="fw-semibold mb-2">底部显示</div>
                        <Popover Title="字段说明"
                                 Content="适合表单字段或紧凑布局中的说明文字。"
                                 Placement="Placement.Bottom"
                                 Trigger="hover focus"
                                 ShowShadow="true">
                            <button type="button" class="btn btn-outline-primary">字段帮助</button>
                        </Popover>
                    </div>
                </div>

                <div class="col-12 col-lg-3">
                    <div class="border rounded p-3 h-100 bg-white">
                        <div class="fw-semibold mb-2">自定义模板</div>
                        <Popover Title="模板内容"
                                 Placement="Placement.Left"
                                 Trigger="click"
                                 ShowShadow="true"
                                 Template="@CardTemplate">
                            <button type="button" class="btn btn-success">查看卡片内容</button>
                        </Popover>
                    </div>
                </div>
            </div>
        </div>
    </div>

@code {
    private RenderFragment CardTemplate => @<div class="p-3" style="max-width: 280px;">
        <div class="fw-bold mb-2">Popover 卡片内容</div>
        <div class="small text-muted mb-3">
            这里是通过 <code>Template</code> 渲染的自定义内容。
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <span class="badge bg-primary">说明</span>
            <span class="badge bg-success">提示</span>
            <span class="badge bg-warning text-dark">帮助</span>
        </div>
    </div>;
}
