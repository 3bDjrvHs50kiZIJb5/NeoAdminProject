@page "/BBDemo/DateTimePickerDemo"

<PageTitle>日期时间与时间选择演示</PageTitle>

<div class="container-fluid py-3 demo-page">
    <div class="card mb-3">
        <div class="card-header">
            <strong>DateTimePicker 演示</strong>
        </div>
        <div class="card-body">
            <p class="text-muted mb-3">
                这个页面分别演示日期时间选择器和时间选择器，方便对比它们的使用场景。
            </p>

            <div class="mb-3">
                <label class="form-label">日期时间</label>
                <DateTimePicker TValue="DateTime?"
                                Value="dateTimeValue"
                                ValueChanged="OnDateTimeChanged"
                                AllowNull="true"
                                IsEditable="true"
                                ShowIcon="true"
                                ViewMode="DatePickerViewMode.DateTime"
                                PickTimeMode="PickTimeMode.Dropdown"
                                Color="Color.Primary" />
            </div>

            <div class="border rounded p-3 bg-light">
                <div>当前值：@FormatDateTime(dateTimeValue)</div>
            </div>

            <p class="text-muted mb-3">
                TimePicker 适合只选择时、分、秒的场景。
            </p>

            <div class="mb-3">
                <label class="form-label">时间</label>
                <TimePicker HasSeconds="true"
                            CancelButtonText="取消"
                            ConfirmButtonText="确定" />
            </div>

            <div class="border rounded p-3 bg-light">
                <div>示例配置：默认显示秒，按钮文字已本地化。</div>
            </div>
        </div>
    </div>
</div>

@code {
    private DateTime? dateTimeValue = DateTime.Now;

    private Task OnDateTimeChanged(DateTime? value)
    {
        dateTimeValue = value;
        return Task.CompletedTask;
    }

    private static string FormatDateTime(DateTime? value) =>
        value.HasValue ? value.Value.ToString("yyyy-MM-dd HH:mm:ss") : "未选择";
}
