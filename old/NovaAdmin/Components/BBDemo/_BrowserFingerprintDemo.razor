@page "/BBDemo/BrowserFingerprintDemo"
@inject IJSRuntime JS

<PageTitle>浏览器指纹演示</PageTitle>

<div class="card">
    <div class="card-header">
        <strong>浏览器指纹演示</strong>
    </div>
    <div class="card-body">
        <p class="text-muted mb-3">
            这个页面演示在 Blazor 里调用 <code>novaAdminJS.getBrowserFingerprint</code>，
            从前端拿到 FingerprintJS 的 <code>visitorId</code>。
        </p>

        <div class="mb-3">
            <div class="fw-semibold mb-2">操作</div>
            <div class="d-flex gap-2 flex-wrap">
                <button type="button" class="btn btn-primary" @onclick="GetFingerprintAsync" disabled="@isLoading">
                    @(isLoading ? "获取中..." : "获取浏览器指纹")
                </button>
                <button type="button" class="btn btn-outline-secondary" @onclick="GetFingerprintAsync" disabled="@isLoading">
                    重新获取
                </button>
            </div>
        </div>

        <div class="mb-3 border rounded p-3 bg-light">
            <div class="text-muted small mb-1">当前状态</div>
            <div class="fw-semibold">@statusText</div>
            <div class="mt-3 text-muted small mb-1">最近获取时间</div>
            <div>@(lastFetchedAt is null ? "-" : lastFetchedAt.Value.ToString("yyyy-MM-dd HH:mm:ss"))</div>
            <div class="mt-3 text-muted small mb-1">错误信息</div>
            <div class="text-danger">@(string.IsNullOrWhiteSpace(errorText) ? "无" : errorText)</div>
        </div>

        <div class="mb-3 border rounded p-3 bg-dark text-light">
            <div class="text-muted small mb-1">返回结果</div>
            <div class="font-monospace text-break">@(string.IsNullOrWhiteSpace(fingerprint) ? "尚未获取" : fingerprint)</div>
        </div>

        <div class="mb-3 border rounded p-3 bg-light">
            <div class="fw-semibold mb-2">说明</div>
            <ul class="mb-0 ps-3">
                <li>页面里的实现调用的是前端 JS 方法，不需要自己直接接触浏览器底层 API。</li>
                <li>拿到的值就是 FingerprintJS 返回的 <code>visitorId</code>。</li>
                <li>如果后端开启了指纹校验，这个值还会参与登录态验证。</li>
            </ul>
        </div>

        <div class="border rounded p-3">
            <div class="text-muted small mb-2">示例代码</div>
            <pre class="mb-0"><code>var fingerprint = await JS.InvokeAsync&lt;string?&gt;("novaAdminJS.getBrowserFingerprint");
if (!string.IsNullOrWhiteSpace(fingerprint))
{
    // 这里就拿到了浏览器指纹
}</code></pre>
        </div>
    </div>
</div>

@code {
    private string? fingerprint;
    private string statusText = "尚未获取";
    private string errorText = string.Empty;
    private bool isLoading;
    private DateTime? lastFetchedAt;
    private bool _autoLoaded;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_autoLoaded)
        {
            _autoLoaded = true;
            await GetFingerprintAsync();
        }
    }

    private async Task GetFingerprintAsync()
    {
        if (isLoading)
        {
            return;
        }

        isLoading = true;
        statusText = "正在获取浏览器指纹...";
        errorText = string.Empty;
        await InvokeAsync(StateHasChanged);

        try
        {
            fingerprint = await JS.InvokeAsync<string?>("novaAdminJS.getBrowserFingerprint");
            lastFetchedAt = DateTime.Now;
            statusText = string.IsNullOrWhiteSpace(fingerprint) ? "获取失败" : "获取成功";
            if (string.IsNullOrWhiteSpace(fingerprint))
            {
                errorText = "前端没有返回有效的指纹值，请检查浏览器控制台或 FingerprintJS 是否加载成功。";
            }
        }
        catch (Exception ex)
        {
            fingerprint = null;
            lastFetchedAt = DateTime.Now;
            statusText = "获取失败";
            errorText = ex.Message;
        }
        finally
        {
            isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }
}
