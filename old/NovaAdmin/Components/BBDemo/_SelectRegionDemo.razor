@page "/BBDemo/SelectRegionDemo"

<PageTitle>省市区选择演示</PageTitle>

<div class="container-fluid py-3 demo-page">
    <div class="card mb-3">
        <div class="card-header">
            <strong>SelectRegion 演示</strong>
        </div>
        <div class="card-body">
            <p class="text-muted mb-3">
                这个页面演示 BootstrapBlazor 的省市区联动选择组件。
            </p>

            <div class="mb-3">
                <label class="form-label">省市区</label>
                <SelectRegion @bind-Value="regionValue" />
            </div>

            <div class="border rounded p-3 bg-light">
                <div class="fw-semibold mb-2">当前值</div>
                <div>@DisplayRegion</div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <strong>示例代码</strong>
        </div>
        <div class="card-body">
            <pre class="mb-0"><code>&lt;SelectRegion &#64;bind-Value="regionValue" /&gt;</code></pre>
        </div>
    </div>
</div>

@code {
    private string? regionValue = "北京市/市辖区/朝阳区";

    private string DisplayRegion => string.IsNullOrWhiteSpace(regionValue)
        ? "未选择"
        : regionValue;
}
