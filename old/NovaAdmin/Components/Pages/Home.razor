            grid-template-columns: 1fr;
        }

        .feature-grid,
        .entry-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 640px) {
        .home-shell {
            width: min(100% - 1rem, 1280px);
        }

        .home-topbar {
            margin-bottom: 1.5rem;
        }

        .brand-mark {
            width: 2.95rem;
            height: 2.95rem;
        }

        .hero-card,
        .aside-card,
        .feature-card,
        .entry-card,
        .note-strip {
            border-radius: 1.25rem;
        }

        .feature-grid,
        .entry-grid {
            grid-template-columns: 1fr;
        }

        .feature-card:nth-child(2),
        .feature-card:nth-child(3) {
            transform: none;
        }

        .hero-actions > .btn {
            width: 100%;
        }
    }
</style>

@code {
    private sealed record FeatureCard(string Index, string Title, string Description, string[] Tags);

    private sealed record QuickLinkCard(string Title, string Description, string Href, string Meta);

    private static readonly FeatureCard[] FeatureCards =
    [
        new(
            "01",
            "统一宿主",
            "Program.cs 把 Blazor 组件、FreeSql、示例数据和静态资源串成一条启动链路，方便在一个入口里完成业务扩展。",
            new[] { "Blazor Server", "FreeSql", "Razor 组件" }),
        new(
            "02",
