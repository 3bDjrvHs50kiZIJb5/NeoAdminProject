@page "/"
@layout LayoutEmpty

<PageTitle>NovaAdmin - 后台管理与 SaaS 中台骨架</PageTitle>

<div class="home-page">
    <div class="home-shell">
        <header class="home-topbar">
            <div class="brand-block">
                <div class="brand-mark">N</div>
                <div class="brand-copy">
                    <span class="brand-name">NovaAdmin</span>
                    <span class="brand-subtitle">后台管理与 SaaS 中台骨架</span>
                </div>
            </div>

            <nav class="home-nav" aria-label="首页导航">
                <a class="home-nav-link" href="#overview">简介</a>
                <a class="home-nav-link" href="/Blog/Article">示例内容</a>
                <a class="home-nav-link home-nav-doc" href="/api/index.html">API 文档</a>
                <a class="home-nav-link home-nav-login" href="/Login?Redirect=%2FAdmin">登录</a>
            </nav>
        </header>

        <main class="home-content">
            <section class="hero-card">
                <div class="hero-copy">
                    <p class="hero-kicker">Blazor Server · FreeSql · BootstrapBlazor</p>
                    <h1 class="hero-title">
                        为业务后台和中台系统
                        <span>准备的一套可二开底座</span>
                    </h1>
                    <p class="hero-text">
                        NovaAdmin 把登录、菜单、权限、示例模块和部署脚本放在同一条启动链路里，
                        适合作为医疗信息化、检验质控和企业管理端的起点，让你少做一轮重复搭建。
                    </p>

                    <div class="hero-actions">
                        <a class="btn btn-lg btn-primary home-primary-btn" href="/Login?Redirect=%2FAdmin">进入登录页</a>
                        <a class="btn btn-lg btn-outline-secondary home-secondary-btn" href="/Blog/Article">查看示例模块</a>
                    </div>

                    <div class="hero-tags" aria-label="首页亮点">
                        <span>统一宿主</span>
                        <span>登录与权限</span>
                        <span>博客示例</span>
                        <span>Docker 部署</span>
                    </div>
                </div>

                <aside class="hero-aside">
                    <div class="aside-card spotlight-card">
                        <span class="spotlight-label">登录导航</span>
                        <h2>从首页直接进入后台</h2>
                        <p>
                            顶部导航和主按钮都已接入登录页，
                            登录后会保留回跳地址，方便继续查看当前页面。
                        </p>
                    </div>

                    <div class="aside-card stack-card">
                        <div class="stack-row">
                            <span>1</span>
                            <div>
                                <strong>页面</strong>
                                <p>Razor 组件 + 路由 + 布局，结构清晰。</p>
                            </div>
                        </div>
                        <div class="stack-row">
                            <span>2</span>
                            <div>
                                <strong>数据</strong>
                                <p>FreeSql + SQLite + 种子数据，开箱即用。</p>
                            </div>
                        </div>
                        <div class="stack-row">
                            <span>3</span>
                            <div>
                                <strong>体验</strong>
                                <p>BootstrapBlazor 主题，延续现有后台风格。</p>
                            </div>
                        </div>
                    </div>
                </aside>
            </section>

            <section id="overview" class="section-block">
                <div class="section-heading">
                    <span class="section-label">项目简介</span>
                    <h2>把常见后台能力组织成可直接起跑的结构</h2>
                    <p>
                        页面、接口、实体与种子数据已经按目录分开，适合在现有框架上继续扩展，
                        也方便后续把你自己的业务页面快速接进来。
                    </p>
                </div>

                <div class="feature-grid">
                    @foreach (var feature in FeatureCards)
                    {
                        <article class="feature-card">
                            <span class="feature-index">@feature.Index</span>
                            <h3>@feature.Title</h3>
                            <p>@feature.Description</p>
                            <div class="feature-meta">
                                @foreach (var tag in feature.Tags)
                                {
                                    <span>@tag</span>
                                }
                            </div>
                        </article>
                    }
                </div>
            </section>

            <section class="section-block">
                <div class="section-heading">
                    <span class="section-label">快速入口</span>
                    <h2>常用页面直接跳转</h2>
                    <p>
                        从首页就可以进入登录、文章、按钮权限、表格和缓存演示页面，
                        方便你快速确认功能链路。
                    </p>
                </div>

                <div class="entry-grid">
                    @foreach (var link in QuickLinks)
                    {
                        <a class="entry-card" href="@link.Href">
                            <span class="entry-meta">@link.Meta</span>
                            <strong>@link.Title</strong>
                            <p>@link.Description</p>
                            <span class="entry-href">立即进入</span>
                        </a>
                    }
                </div>
            </section>

            <section class="note-strip">
                <div>
                    <span class="note-label">默认账号</span>
                    <p>
                        首次运行后的默认账号请以实际种子数据为准；
                        如果你已经配置了自己的管理员账号，直接使用右上角登录入口即可。
                    </p>
                </div>
            </section>
        </main>
    </div>
</div>

<style>
