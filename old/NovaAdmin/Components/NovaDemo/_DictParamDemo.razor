@page "/NovaDemo/DictParamDemo"
@inject Microsoft.Extensions.Logging.ILogger<_DictParamDemo> Logger

<PageTitle>字典和参数配置演示</PageTitle>

    <div class="card mb-3">
        <div class="card-header">
            <strong>字典和参数配置演示</strong>
        </div>
        <div class="card-body">
            <p class="text-muted mb-3">
                这个页面演示字典选择和参数读取两种常见场景。
            </p>

            <div class="row g-3">
                <div class="col-12 col-lg-6">
                    <div class="border rounded p-3 h-100 bg-white">
                        <div class="fw-semibold mb-2">字典快速演示</div>
                        <p class="small text-muted mb-3">
                            字典分类使用 <code>Gender</code>，可在 <a href="/Admin/Dict">/Admin/Dict</a> 中直接维护。
                        </p>

                        <div class="form-group rounded-3 p-3" style="background-color: #edf6f5; border: 1px solid #d7e9e6;">
                            <label class="form-label mb-2" style="color: #244b50; font-weight: 600;">性别字典</label>
                            <NovaSelectDict ParentName="Gender" @bind-Value="selectedGender" OnValueChanged="OnGenderChanged" />
                        </div>

                        <div class="mt-3 small" style="color: #6b7280;">
                            当前选中值：
                            <span class="fw-semibold" style="color: #0f3d46;">@(string.IsNullOrWhiteSpace(selectedGender) ? "未选择" : selectedGender)</span>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-lg-6">
                    <div class="border rounded p-3 h-100 bg-white">
                        <div class="fw-semibold mb-2">参数配置演示</div>
                        <p class="small text-muted mb-3">
                            参数编码使用 <code>Home_ContactCard</code>，当前卡片通过 <code>NovaParamText</code> 读取 <code>Value</code>、<code>Value2</code>、<code>Value3</code>。<br />
                            你可以前往 <a href="/Admin/Param">/Admin/Param</a> 新增或修改这个参数。
                        </p>

                        <div class="rounded-3 p-3" style="background-color: #f6f2ea; border: 1px dashed #d7c4a1;">
                            <div class="small mb-1" style="color: #8a6b3d;">当前参数编码</div>
                            <div class="fw-semibold" style="color: #3b2c18;">Home_ContactCard</div>

                            <div class="mt-3 small mb-1" style="color: #8a6b3d;">标题</div>
                            <NovaParamText ParamId="Home_ContactCard" Field="@nameof(SysParam.Value)" DefaultText="未配置" TagName="div" Style="color: #2c241b;" />

                            <div class="mt-3 small mb-1" style="color: #8a6b3d;">正文</div>
                            <NovaParamText ParamId="Home_ContactCard" Field="@nameof(SysParam.Value2)" DefaultText="未配置，请到 /Admin/Param 新增 Home_ContactCard 参数。" TagName="div" Style="color: #4b5563; line-height: 1.8;" />

                            <div class="mt-3 small mb-1" style="color: #8a6b3d;">联系电话</div>
                            <NovaParamText ParamId="Home_ContactCard" Field="@nameof(SysParam.Value3)" DefaultText="未配置" TagName="div" Class="fw-semibold" Style="color: #7c5a20;" />
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

@code {
    private string selectedGender = string.Empty;

    protected override void OnInitialized()
    {
        Logger.LogInformation("_DictParamDemo page initialized.");
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            Logger.LogInformation("_DictParamDemo page rendered for the first time.");
        }
    }

    private Task OnGenderChanged(string value)
    {
        Logger.LogInformation("_DictParamDemo dictionary changed. ParentName=Gender, Value={Value}", value);
        return Task.CompletedTask;
    }
}
