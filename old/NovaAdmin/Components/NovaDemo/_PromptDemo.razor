@page "/NovaDemo/PromptDemo"
@using BootstrapBlazor.Components

<PageTitle>提示类演示</PageTitle>

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card mb-3">
                <div class="card-header">
                    <strong>提示类组件演示</strong>
                </div>
                <div class="card-body">
                    <p class="mb-2">
                        这个页面演示 <code>Toast</code>、<code>Message</code> 和 <code>Confirm</code> 的实际用法。
                    </p>
                    <ul class="mb-0">
                        <li><code>ToastServiceExtensions</code>：短时间浮层提示</li>
                        <li><code>MessageService</code>：页面内业务提示</li>
                        <li><code>JS.Confirm</code>：执行前确认</li>
                        <li><code>PopConfirmButton</code>：按钮级确认</li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-6 mb-3">
            <div class="card h-100">
                <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-2">
                    <strong>Toast 演示</strong>
                    <span class="text-muted small">短提示，适合成功/失败/警告</span>
                </div>
                <div class="card-body">
                    <div class="d-flex gap-2 flex-wrap mb-3">
                        <button type="button" class="btn btn-success" @onclick="ShowToastSuccess">成功 Toast</button>
                        <button type="button" class="btn btn-danger" @onclick="ShowToastError">错误 Toast</button>
                        <button type="button" class="btn btn-warning" @onclick="ShowToastWarning">警告 Toast</button>
                    </div>
                    <div class="small text-muted">最近一次：@toastStatus</div>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-6 mb-3">
            <div class="card h-100">
                <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-2">
                    <strong>Message 演示</strong>
                    <span class="text-muted small">页面内提示，适合规则拦截</span>
                </div>
                <div class="card-body">
                    <div class="d-flex gap-2 flex-wrap mb-3">
                        <button type="button" class="btn btn-outline-primary" @onclick="ShowMessageInfo">普通消息</button>
                        <button type="button" class="btn btn-outline-success" @onclick="ShowMessageSuccess">成功消息</button>
                        <button type="button" class="btn btn-outline-danger" @onclick="ShowMessageError">错误消息</button>
                    </div>
                    <div class="small text-muted">最近一次：@messageStatus</div>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-6 mb-3">
            <div class="card h-100">
                <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-2">
                    <strong>Confirm 演示</strong>
                    <span class="text-muted small">执行前二次确认</span>
                </div>
                <div class="card-body">
                    <div class="d-flex gap-2 flex-wrap mb-3">
                        <button type="button" class="btn btn-outline-danger" @onclick="DeleteByConfirm">JS.Confirm 删除</button>
                    </div>
                    <div class="small text-muted">最近一次：@confirmStatus</div>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-6 mb-3">
            <div class="card h-100">
                <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-2">
                    <strong>PopConfirmButton 演示</strong>
                    <span class="text-muted small">按钮自带确认气泡</span>
                </div>
                <div class="card-body">
                    <PopConfirmButton Color="Color.Danger" Content="确定要执行这个演示动作吗？" OnConfirm="OnPopConfirm" ConfirmButtonColor="Color.Danger" ConfirmIcon="fa-solid fa-triangle-exclamation text-danger">
                        <i class="fa fa-trash-alt"></i> PopConfirm 删除
                    </PopConfirmButton>
                    <div class="small text-muted mt-3">最近一次：@popConfirmStatus</div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string toastStatus = "尚未触发";
    private string messageStatus = "尚未触发";
    private string confirmStatus = "尚未触发";
    private string popConfirmStatus = "尚未触发";

    private async Task ShowToastSuccess()
    {
        toastStatus = "成功 Toast";
        await ToastServiceExtensions.Success(ToastService, "提示", "操作已经成功完成。", true);
    }

    private async Task ShowToastError()
    {
        toastStatus = "错误 Toast";
        await ToastServiceExtensions.Error(ToastService, "提示", "这里是一个错误示例。", true);
    }

    private async Task ShowToastWarning()
    {
        toastStatus = "警告 Toast";
        await ToastServiceExtensions.Warning(ToastService, "提示", "这里是一个警告示例。", true);
    }

    private async Task ShowMessageInfo()
    {
        messageStatus = "普通消息";
        await MessageService.Show(new MessageOption
        {
            Color = Color.Info,
            Content = "这是一个普通消息提示。"
        }, null);
    }

    private async Task ShowMessageSuccess()
    {
        messageStatus = "成功消息";
        await MessageService.Show(new MessageOption
        {
            Color = Color.Success,
            Content = "这是一个成功消息提示。"
        }, null);
    }

    private async Task ShowMessageError()
    {
        messageStatus = "错误消息";
        await MessageService.Show(new MessageOption
        {
            Color = Color.Danger,
            Content = "这是一个错误消息提示。"
        }, null);
    }

    private async Task DeleteByConfirm()
    {
        if (!await JS.Confirm("确定要删除这条演示记录吗？", "删除之后无法恢复！"))
        {
            confirmStatus = "用户取消了确认";
            return;
        }

        confirmStatus = "用户确认后执行删除逻辑";
        await ToastServiceExtensions.Success(ToastService, "确认", "已执行删除动作演示。", true);
    }

    private async Task OnPopConfirm()
    {
        popConfirmStatus = "PopConfirmButton 已确认";
        await ToastServiceExtensions.Success(ToastService, "确认", "PopConfirmButton 的确认逻辑已触发。", true);
    }
}
